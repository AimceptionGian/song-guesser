# ─── SongGuesser Environment Variables ───

# Jamendo API (optional – music catalog fallback)
# Register at https://devportal.jamendo.com/ to get a client ID
JAMENDO_CLIENT_ID=""

# Spotify OAuth (optional – history sync)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Cloudflare (required for deployment)
# Create an API token at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=""

# MongoDB Atlas Data API (optional – persistent storage)
# Create a Data API key in your Atlas cluster:
# https://www.mongodb.com/docs/atlas/api/data-api/
MONGODB_API_URL="https://<region>.data.mongodb-api.com/app/<app-id>/endpoint/data/v1"
MONGODB_API_KEY=""
MONGODB_DATABASE="song-guesser"
MONGODB_LOBBY_COLLECTION="lobbies"
MONGODB_SESSION_COLLECTION="sessions"
MONGODB_MATCH_COLLECTION="matches"